<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:baselineAligned="true">

        <!-- Верхний бар с заголовком приложения и разделом -->
        <androidx.cardview.widget.CardView
            android:id="@+id/topBarCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Первая строка с иконкой и названием -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/car_logo"
                        android:contentDescription="Иконка автомобиля"
                         />

                    <TextView
                        android:id="@+id/appTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="АВТО.СКР"
                        android:textColor="@color/primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.3"
                        android:importantForAccessibility="yes" />

                </LinearLayout>

                <!-- Разделитель -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="8dp"
                    android:background="@color/outline" />

                <!-- Заголовок раздела -->
                <TextView
                    android:id="@+id/sectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Доступные автомобили"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:importantForAccessibility="yes" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Фильтры и сортировка -->
        <androidx.cardview.widget.CardView
            android:id="@+id/filtersCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/topBarCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Существующие фильтры -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="true">

                    <!-- Фильтр по типу -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:minWidth="120dp"
                        app:boxBackgroundColor="@color/input_background"
                        app:endIconMode="dropdown_menu"
                        app:endIconTint="@color/primary"
                        app:startIconDrawable="@drawable/ic_car_type"
                        app:startIconTint="@color/primary"
                        android:importantForAccessibility="yes"
                        android:hint="@string/car_type_hint">

                        <AutoCompleteTextView
                            android:id="@+id/typeFilter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:labelFor="@+id/typeFilter"
                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:minWidth="100dp"
                            android:maxWidth="150dp"
                            android:hint="@string/car_type_hint"
                            android:importantForAccessibility="no" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Фильтр по цене -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="120dp"
                        android:hint="@string/price_hint"
                        app:boxBackgroundColor="@color/input_background"
                        app:endIconMode="dropdown_menu"
                        app:endIconTint="@color/primary"
                        app:startIconDrawable="@drawable/ic_price"
                        app:startIconTint="@color/primary"
                        android:importantForAccessibility="yes"
                        android:contentDescription="@string/price_filter_desc">

                        <AutoCompleteTextView
                            android:id="@+id/priceFilter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:labelFor="@+id/priceFilter"
                            android:textSize="14sp"
                            android:textColor="@color/black"
                            android:minWidth="100dp"
                            android:maxWidth="150dp"
                            android:hint="@string/price_hint"
                            android:importantForAccessibility="no" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Статистика и информация -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/filtersCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="true"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/totalCarsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_cars_default"
                        android:textColor="@color/dark_blue"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_cars_label"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:importantForAccessibility="yes" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/outline"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/availableCarsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/available_cars_default"
                        android:textColor="@color/primary_dark"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/available_cars_label"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:importantForAccessibility="yes" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/outline"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/avgPriceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_price_default"
                        android:textColor="@color/accent_blue"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/avg_price_label"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:importantForAccessibility="yes" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Список автомобилей -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/carsRecyclerView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:contentDescription="@string/cars_list_desc"
            android:importantForAccessibility="yes"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="1"
            app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/statsCard" />

        <!-- Кнопка добавления нового автомобиля -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddCar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/add_car"
            android:src="@drawable/ic_add"
            android:visibility="gone"
            android:importantForAccessibility="yes"
            app:backgroundTint="@color/primary"
            app:layout_constraintBottom_toTopOf="@+id/bottomNavigation"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/white" />

        <!-- Нижняя навигационная панель -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:background="@color/surface"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:importantForAccessibility="yes"
            app:elevation="8dp"
            app:itemIconTint="@drawable/bottom_nav_colors"
            app:itemTextColor="@drawable/bottom_nav_colors"
            app:labelVisibilityMode="labeled"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:menu="@menu/bottom_nav_menu" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>